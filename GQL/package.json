{
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">= 26"
  },
  "imports": {
    "#/*": "./*",
    "#database/*": "./database/*",
    "#generated/*": "./generated/*",
    "#resolvers/*": "./resolvers/*",
    "#staticData/*": "./staticData/*",
    "#utils/*": "./utils/*"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dumpSchema": "tsx ./utils/dump-schema.mts",
    "graphQlGen": "graphql-codegen --config codegen.yml",
    "prettier": "prettier --write './**/*.{mts,js,graphql}'",
    "start": "tsx index.mts",
    "startDev": "tsx --watch index.mts",
    "startDocker": "docker compose up --build -d",
    "prismaPull": "prisma db pull",
    "prismaGen": "prisma generate --sql",
    "prismaFormat": "prisma format",
    "build:dist": "dotenv -e .env -- node ./tools/build-esbuild.mjs",
    "build": "prisma generate --sql && dotenv -e .env -- sh -lc \"DOCKER_BUILDKIT=1 docker buildx build --platform linux/arm64 --no-cache --progress=plain --build-arg DATABASE_URL=\\\"$DATABASE_URL\\\" -t mattsarz78/graphql:latest .\"",
    "lint": "eslint .",
    "lintFix": "eslint . --fix",
    "dockerRun": "docker run --name gql -p 8020:8020 mattsarz78/graphql:latest",
    "tagImage": "docker tag mattsarz78/graphql:latest mattsarz78/graphql:latest",
    "pushImage": "docker push mattsarz78/graphql:latest",
    "pullImage": "docker pull mattsarz78/graphql:latest"
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@as-integrations/express5": "1.1.2",
    "@dotenvx/dotenvx": "2.11.1",
    "@graphql-tools/graphql-file-loader": "8.1.16",
    "@graphql-tools/load": "8.1.13",
    "@graphql-tools/merge": "9.2.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "body-parser": "2.3.0",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "graphql": "17.0.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-resolvers": "6.1.0",
    "@types/body-parser": "1.19.6",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "dotenv-cli": "11.0.0",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0"
  },
  "graphql": {
    "schema": "./schema.graphql",
    "documents": "./**/*.{graphql,js,mts,jsx,tsx}"
  },
  "packageManager": "pnpm@11.10.0"
}
