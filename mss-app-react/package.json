{
  "name": "mss-app-react",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">= 24"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*"
    ],
    "#views/*": [
      "./src/views/*"
    ],
    "#utils/*": [
      "./src/utils/*"
    ],
    "#conference/*": [
      "./src/components/conference/*"
    ],
    "#noTv/*": [
      "./src/components/noTVGames/*"
    ],
    "#season/*": [
      "./src/components/season/*"
    ],
    "#shared/*": [
      "./src/components/shared/*"
    ],
    "#weekly/*": [
      "./src/components/weekly/*"
    ],
    "#text/*": [
      "./src/components/weeklyText/*"
    ],
    "#data/*": [
      "./src/staticData/*"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "pnpm type-check && pnpm build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "tsc --build --force",
    "lint": "eslint .",
    "lintFix": "eslint . --fix",
    "format": "prettier --write ./",
    "copy-webp": "node ./scripts/copy-webp.mjs"
  },
  "dependencies": {
    "@apollo/client": "4.2.3",
    "dompurify": "^3.4.9",
    "graphql": "16.14.2",
    "luxon": "3.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "7.17.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@apollo/client-devtools-vscode": "4.25.6",
    "@eslint/js": "^10.0.1",
    "@rushstack/eslint-patch": "1.16.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "^0.28.1",
    "eslint": "10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "^17.6.0",
    "rollup-plugin-visualizer": "7.0.1",
    "sharp": "0.35.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0"
  },
  "graphql": {
    "schema": "./schema.graphql",
    "documents": "./src/**/*.{graphql,js,mts,jsx,tsx}"
  },
  "packageManager": "pnpm@11.5.1"
}
