{
  "name": "mss-app-react",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">= 24"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*"
    ],
    "#views/*": [
      "./src/views/*"
    ],
    "#utils/*": [
      "./src/utils/*"
    ],
    "#conference/*": [
      "./src/components/conference/*"
    ],
    "#noTv/*": [
      "./src/components/noTVGames/*"
    ],
    "#season/*": [
      "./src/components/season/*"
    ],
    "#shared/*": [
      "./src/components/shared/*"
    ],
    "#weekly/*": [
      "./src/components/weekly/*"
    ],
    "#text/*": [
      "./src/components/weeklyText/*"
    ],
    "#data/*": [
      "./src/staticData/*"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "pnpm type-check && pnpm build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "tsc --build --force",
    "lint": "eslint .",
    "lintFix": "eslint . --fix",
    "format": "prettier --write ./"
  },
  "dependencies": {
    "@apollo/client": "4.2.3",
    "dompurify": "3.4.11",
    "graphql": "17.0.1",
    "luxon": "3.7.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "workbox-window": "7.4.1"
  },
  "devDependencies": {
    "@apollo/client-devtools-vscode": "4.25.6",
    "@eslint/js": "10.0.1",
    "@types/luxon": "3.7.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0"
  },
  "graphql": {
    "schema": "./schema.graphql",
    "documents": "./src/**/*.{graphql,js,mts,jsx,tsx}"
  },
  "packageManager": "pnpm@11.7.0"
}
