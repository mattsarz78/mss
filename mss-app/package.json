{
  "name": "mss-app",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">= 24"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*"
    ],
    "#composables/*": [
      "./src/composables/*"
    ],
    "#views/*": [
      "./src/views/*"
    ],
    "#utils/*": [
      "./src/utils/*"
    ],
    "#conference/*": [
      "./src/components/conference/*"
    ],
    "#noTv/*": [
      "./src/components/noTVGames/*"
    ],
    "#season/*": [
      "./src/components/season/*"
    ],
    "#shared/*": [
      "./src/components/shared/*"
    ],
    "#weekly/*": [
      "./src/components/weekly/*"
    ],
    "#text/*": [
      "./src/components/weeklyText/*"
    ],
    "#data/*": [
      "./src/staticData/*"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "pnpm type-check && pnpm build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lintFix": "eslint . --fix",
    "format": "prettier --write ./",
    "copy-webp": "node ./scripts/copy-webp.mjs"
  },
  "dependencies": {
    "@apollo/client": "4.2.0",
    "@vue/apollo-composable": "5.0.0-alpha.2",
    "graphql": "16.14.1",
    "luxon": "3.7.2",
    "vue": "3.5.34",
    "vue-dompurify-html": "5.3.0",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@apollo/client-devtools-vscode": "4.25.6",
    "@rushstack/eslint-patch": "1.16.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "eslint-plugin-vue": "10.9.1",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "rollup-plugin-visualizer": "7.0.1",
    "sharp": "0.34.5",
    "vite": "8.0.14",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-vue-devtools": "8.1.2",
    "vue-tsc": "3.3.2"
  },
  "graphql": {
    "schema": "./schema.graphql",
    "documents": "./src/**/*.{graphql,js,mts,jsx,tsx}"
  },
  "packageManager": "pnpm@11.1.3"
}
